<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_oidc_res_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.oidc</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" eval="False"/>
        <field name="arch" type="xml">
            <form string="OIDC Settings">
                <header>
                    <button name="execute" string="Save" type="object" class="btn-primary oe_highlight"/>
                    <button string="Discard" special="cancel" class="btn-secondary"/>
                </header>
                <sheet>
                    <group string="OIDC Provider Settings" colspan="4">
                        <group col="2">
                            <field name="oidc_require_https" widget="boolean_toggle"/>
                            <label for="oidc_require_https"/>
                            <div class="text-muted">Require HTTPS for all OpenID Connect endpoints (recommended).</div>
                        </group>
                        <group col="2">
                            <field name="oidc_require_pkce_public" widget="boolean_toggle"/>
                            <label for="oidc_require_pkce_public"/>
                            <div class="text-muted">Enforce PKCE (RFC 7636) for public (non-confidential) clients.</div>
                        </group>
                        <group col="2">
                            <field name="oidc_pkce_require_s256" widget="boolean_toggle"/>
                            <label for="oidc_pkce_require_s256"/>
                            <div class="text-muted">Require PKCE S256 (disallow plain code_challenge_method).</div>
                        </group>
                        <group col="2">
                            <field name="oidc_require_nonce" widget="boolean_toggle"/>
                            <label for="oidc_require_nonce"/>
                            <div class="text-muted">Require nonce on OpenID Connect authorization requests (OIDC Core 3.1.2.1).</div>
                        </group>
                        <group col="2">
                            <field name="oidc_allow_external_redirects" widget="boolean_toggle"/>
                            <label for="oidc_allow_external_redirects"/>
                            <div class="text-muted">Allow redirects to registered external redirect_uris (OIDC Core 3.1.2.5).</div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_oidc_settings" model="ir.actions.act_window">
        <field name="name">OIDC Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_oidc_res_config_settings"/>
        <field name="target">inline</field>
        <field name="context">{'module': 'odoo_oidc_provider'}</field>
    </record>

    <menuitem id="menu_oidc_config_settings" name="Settings"
              parent="menu_auth_oidc_config" action="action_oidc_settings"
              groups="base.group_system" sequence="5"/>
</odoo>
